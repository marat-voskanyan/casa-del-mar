# Copy this file to .env.local and fill in values

# JWT secret — change to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-string

# Groq API key — free at https://console.groq.com (no credit card needed)
GROQ_API_KEY=gsk_your-groq-key-here

# DeepL API key — free at https://www.deepl.com/pro-api (500k chars/month, no credit card)
DEEPL_API_KEY=your-deepl-key-here

# Absolute path to the SQLite database file
# For Vercel: consider using Turso (https://turso.tech) or Neon instead
DATABASE_PATH=./data/casa.db

# Site metadata
NEXT_PUBLIC_SITE_ID=69021918-94ab-48db-9e03-ca90f1a79617
NEXT_PUBLIC_SITE_NAME=Casa del Mar
NEXT_PUBLIC_SITE_URL=https://casadelmar.eu
